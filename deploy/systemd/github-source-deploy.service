[Unit]
Description=Deploy GitHub-owned site sources to vBook renderers
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=henk
Group=henk
Environment=HOME=/home/henk
ExecStart=/usr/bin/flock -w 300 /home/henk/.cache/markdownmanager/render.lock /usr/bin/python3 /srv/vbook_web/bin/github_source_deploy.py --config /home/henk/github_sources/github-source-deploy.json
